NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tawjeeh

# JWT Secrets — change these to long random strings!
# JWT_SECRET_OLD is set automatically by rotate-jwt.sh during rotation (leave blank initially)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_SECRET_OLD=
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Askara / AI Chat (shared across chat + general AI features) ─────────────
# These keys are used by ai.ts (Askara chat) and general-purpose AI calls.
OPENAI_API_KEY=sk-...your-openai-chat-key-here
DEEPSEEK_API_KEY=sk-...your-deepseek-key-here
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here
GROQ_API_KEY=gsk_...your-groq-chat-key-here

# Résumé cours (POST /ai/resources/:id/summary) — OBLIGATOIRE, sans repli sur les autres clés Groq
SUMMARY_AI_GROQ_API_KEY=gsk_...same-or-dedicated-key

# Scan-deck + fallback chat : même résolution que Whisper —
# WHISPER_GROQ_API_KEY si définie, sinon GROQ_API_KEY.

# ─── Whisper (voice transcription only) ──────────────────────────────────────
# Dedicated keys for voice-note transcription + AI enhancement in Whisper Studio.
# If a WHISPER_* key is unset, the server falls back to the matching Askara key
# above, so existing deployments keep working without modification.
# Define these to bill / monitor voice transcription separately from chat.
WHISPER_OPENAI_API_KEY=sk-...your-openai-whisper-key-here
WHISPER_GROQ_API_KEY=gsk_...your-groq-whisper-key-here
WHISPER_GOOGLE_CLOUD_API_KEY=AIza...your-google-cloud-stt-key-here

# Audio upload directory for voice notes
AUDIO_DIR=./uploads/audio

# Google Gemini (AI Studio) — used for docs/OCR (Gemini Flash)
GOOGLE_API_KEY=AIza...your-google-ai-studio-key-here

# VIP routing (ultra limité, jamais défaut)
# Active un moteur VIP uniquement si l’entitlement `vip_model_access` est TRUE (via feature_flags)
# et si la demande est “très lourde” (score + longueur).
OPENAI_VIP_CHAT_MODEL=gpt-5.4
AI_ROUTING_LOG_DB=false

# Scraper (optional — set to true to enable the daily 06:00 cron job)
SCRAPER_ENABLED=false
ADMIN_EMAIL=admin@tawjeeh.mr
ADMIN_PASSWORD=
DAILY_RECORDING_LIMIT_MINUTES=10
