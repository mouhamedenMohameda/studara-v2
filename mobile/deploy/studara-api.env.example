PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/studara
JWT_SECRET=change-me-min-32-chars

# Queue
REDIS_URL=redis://redis:6379

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL_LONG=gpt-4o

# Upload storage (inside container)
AI_UPLOAD_DIR=uploads/ai

# Limits
AI_MAX_UPLOAD_MB=20
AI_MAX_INPUT_CHARS_FREE=60000
AI_MAX_SUMMARIES_PER_MONTH_FREE=10

