# Copier vers api/.env pour le dev local :  cp env.example .env
# Ou réutiliser deploy/api.env (chargé automatiquement par deploy/ecosystem.config.js sous PM2).

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tawjeeh
JWT_SECRET=change_me_minimum_32_characters_long_string
JWT_REFRESH_SECRET=change_me_another_32_characters_minimum

# OpenAI (used by "Résumé intelligent de cours" upload flow)
OPENAI_API_KEY=
# Dedicated key for course summaries (optional; overrides OPENAI_API_KEY)
SUMARRY_OPENAI_API_KEY=

# Groq — https://console.groq.com/keys
# Résumé cours (obligatoire, pas de fallback) :
SUMMARY_AI_GROQ_API_KEY=gsk_remplacer_par_ta_cle
# Autres routes IA (Whisper → GROQ) :
# WHISPER_GROQ_API_KEY=gsk_remplacer_par_ta_cle
GROQ_API_KEY=gsk_remplacer_par_ta_cle

# ─── Push (Expo) — for "trusted device" password reset approvals ─────────────
EXPO_PUSH_ENABLED=true

# Password reset timings (minutes)
PASSWORD_RESET_INTENT_TTL_MIN=20
PASSWORD_RESET_TICKET_TTL_MIN=5

# CORS (production only) — optional additional allowed web origins (comma-separated)
# CORS_ORIGINS=https://admin.example.com,https://staging.example.com
CORS_ORIGINS=
